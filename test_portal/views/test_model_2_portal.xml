<?xml version= "1.0" encoding="utf-8"?>
<odoo>

  <template id="test_portal.portal_my_test_model_portal" name="My Test Model Portal">
    <t t-call="portal.portal_layout">
      <t t-set="o_portal_fullwidth_alert">
        <t t-call="portal.portal_back_in_edit_mode">
          <t t-set="backend_url"
             t-value="'/web#return_label=Website&amp;model=test_portal.test.model.portal&amp;id=%s&amp;view_type=form' % (test_model_portal.id)"/>
        </t>
      </t>
      <t t-call="portal.portal_record_layout">
        <t t-set="card_header">
          <h5 class="mb-0">
            <small class="text-muted">Test Model Portal -</small>
            <span t-field="test_model_portal.name"/>
          </h5>
        </t>
      </t>
    </t>
  </template>

  <template id="test_portal.portal_my_test_model_2_portal" name="My Test Model_2 Portal">
    <t t-call="portal.portal_layout">
      <t t-set="o_portal_fullwidth_alert">
        <t t-call="portal.portal_back_in_edit_mode">
          <t t-set="backend_url"
             t-value="'/web#return_label=Website&amp;model=test_portal.test.model_2.portal&amp;id=%s&amp;view_type=form' % (test_model_2_portal.id)"/>
        </t>
      </t>
      <t t-call="portal.portal_record_layout">
        <t t-set="card_header">
          <h5 class="mb-0">
            <small class="text-muted">Test Model_2 Portal -</small>
            <span t-field="test_model_2_portal.name"/>
          </h5>
        </t>
      </t>
    </t>
  </template>

  <record model="ir.ui.view" id="test_model_2_portal_treeview">
    <field name="name">test_model_2_portal_tree</field>
    <field name="model">test.model_2.portal</field>
    <field name="arch" type="xml">
      <tree editable="top">
        <field name="model_1"/>
        <field name="name"/>
      </tree>
    </field>
  </record>

  <template id="test_portal.portal_my_test_model_portals" name="My Test Model Portals">
    <t t-call="portal.portal_layout">
      <t t-set="breadcrumbs_searchbar" t-value="True"/>
      <t t-call="portal.portal_searchbar">
        <t t-set="title">Test Model Portals</t>
      </t>
      <t t-if="not test_model_portals">
        <div class="alert alert-warning mt8" role="alert">There are no test_model_portals.</div>
      </t>
      <t t-if="test_model_portals" t-call="portal.portal_table">
        <tbody>
          <tr t-foreach="test_model_portals" t-as="test_model_portal">
            <td>
              <a t-attf-href="/my/test_model_portal/#{test_model_portal.id}?{{ keep_query() }}">
                <span t-field="test_model_portal.name"/>
              </a>
            </td>
            <td class="text-right"/>
          </tr>
        </tbody>
      </t>
    </t>
  </template>

  <template id="test_portal.portal_my_test_model_2_portals" name="My Test Model_2 Portals">
    <t t-call="portal.portal_layout">
      <t t-set="breadcrumbs_searchbar" t-value="True"/>
      <t t-call="portal.portal_searchbar">
        <t t-set="title">Test Model_2 Portals</t>
      </t>
      <t t-if="not test_model_2_portals">
        <div class="alert alert-warning mt8" role="alert">There are no test_model_2_portals.</div>
      </t>
      <t t-if="test_model_2_portals" t-call="portal.portal_table">
        <tbody>
          <tr t-foreach="test_model_2_portals" t-as="test_model_2_portal">
            <td>
              <a t-attf-href="/my/test_model_2_portal/#{test_model_2_portal.id}?{{ keep_query() }}">
                <span t-field="test_model_2_portal.name"/>
              </a>
            </td>
            <td class="text-right"/>
          </tr>
        </tbody>
      </t>
    </t>
  </template>

  <template id="test_portal.portal_my_home" name="Portal My Home: Test_Portal entries"
            inherit_id="portal.portal_my_home">
    <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
      <t t-if="test_model_2_portal_count" t-call="portal.portal_docs_entry">
        <t t-set="title">Test Model_2 Portals</t>
        <t t-set="url" t-value="'/my/test_model_2_portals'"/>
        <t t-set="count" t-value="test_model_2_portal_count"/>
      </t>
      <t t-if="test_model_portal_count" t-call="portal.portal_docs_entry">
        <t t-set="title">Test Model Portals</t>
        <t t-set="url" t-value="'/my/test_model_portals'"/>
        <t t-set="count" t-value="test_model_portal_count"/>
      </t>
    </xpath>
  </template>

  <template id="test_portal.portal_layout" name="Portal layout: Test_Portal menu entry"
            inherit_id="portal.portal_breadcrumbs">
    <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
      <li t-if="page_name == 'test_model_2_portal' or test_model_2_portal"
          t-attf-class="breadcrumb-item #{'active ' if not test_model_2_portal else ''}">
        <a t-if="test_model_2_portal" t-attf-href="/my/test_model_2_portals?{{ keep_query() }}">Test Model_2 Portals</a>
        <t t-else="">Test Model_2 Portals</t>
      </li>
      <li t-if="test_model_2_portal" class="breadcrumb-item active">
        <t t-esc="test_model_2_portal.name"/>
      </li>
      <li t-if="page_name == 'test_model_portal' or test_model_portal"
          t-attf-class="breadcrumb-item #{'active ' if not test_model_portal else ''}">
        <a t-if="test_model_portal" t-attf-href="/my/test_model_portals?{{ keep_query() }}">Test Model Portals</a>
        <t t-else="">Test Model Portals</t>
      </li>
      <li t-if="test_model_portal" class="breadcrumb-item active">
        <t t-esc="test_model_portal.name"/>
      </li>
    </xpath>
  </template>

  <record model="ir.actions.act_window" id="test_model_2_portal_test_model_2_portal_action_view_actionwindow">
    <field name="name">test_model_2_portal_action_view</field>
    <field name="res_model">test.model_2.portal</field>
  </record>

</odoo>